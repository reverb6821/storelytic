        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "A list of companies.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Company"
              }
            }
          },
          "400": {
            "description": "No companies found"
          },
          "404": {
            "description": "No companies found"
          }
        },
        "security": [
          {
            "api_key": []
          }
        ]
